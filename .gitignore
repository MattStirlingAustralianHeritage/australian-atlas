# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# scrape cache
/.cache/

# audit output
/audit/

# one-off diagnostic scripts (underscore prefix convention)
/scripts/_*

# script output and logs
/scripts/output/
/scripts/region-reassign-logs/
dry-run-*

# supabase CLI local state
/supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
